# ============================================
# Plannfly Backend - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# --------------------------------------------
# DATABASE
# --------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/plannfly"

# --------------------------------------------
# JWT (Autenticação)
# --------------------------------------------
# IMPORTANTE: Gere uma chave segura com:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="sua-chave-secreta-com-pelo-menos-32-caracteres"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --------------------------------------------
# GOOGLE OAUTH
# --------------------------------------------
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# --------------------------------------------
# FRONTEND
# --------------------------------------------
FRONTEND_URL="http://localhost:3001"

# --------------------------------------------
# SERVER
# --------------------------------------------
PORT=3000
NODE_ENV="development"

# --------------------------------------------
# ABACATEPAY (Pagamentos)
# --------------------------------------------
# API key da sua conta AbacatePay
ABACATEPAY_API_KEY="abc_..."
# Secret usado na query string do webhook para validação
ABACATEPAY_WEBHOOK_SECRET="secret123"
# Chave pública HMAC para validar assinatura do webhook (da doc AbacatePay)
ABACATEPAY_HMAC_PUBLIC_KEY=""
# Preço em centavos (ex: 2990 = R$29,90)
ABACATEPAY_PRICE=2990

# --------------------------------------------
# WAHA (WhatsApp HTTP API)
# --------------------------------------------
# URL do servidor WAHA (self-hosted)
WAHA_API_URL="http://localhost:3100"
# API Key do WAHA (opcional, se autenticação estiver habilitada)
WAHA_API_KEY=""

# --------------------------------------------
# OPTIONAL (Futuro - v1/v2)
# --------------------------------------------
# N8N_WEBHOOK_URL=""
